{
  "manifest_version": 3,
  "name": "枭雄汉化",
  "version": "1.0.0",
  "description": "自动汉化 Owlbear Rodeo 界面中的英文 TRPG 术语",
  "icons": {
    "128": "icon.svg"
  },
  "content_scripts": [{
    "matches": ["https://www.owlbear.rodeo/*"],
    "js": ["dictionary.js", "content.js"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_popup": "popup.html",
    "default_title": "枭雄汉化"
  },
  "permissions": ["storage"]
}
